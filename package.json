{
  "name": "taro-shadcn-monorepo",
  "private": true,
  "description": "Taro Shadcn UI Component Library Workspace",
  "scripts": {
    "dev:docs": "pnpm --filter @taro-shadcn/docs dev:web",
    "build:docs": "pnpm --filter @taro-shadcn/docs build:web",
    "validate": "pnpm --filter @taro-shadcn/docs validate",
    "lint": "pnpm --filter \"*\" lint",
    "tsc": "pnpm --filter \"*\" tsc",
    "test": "pnpm run test:ci",
    "test:ci": "pnpm --filter taro-shadcn typecheck && pnpm --filter taro-shadcn test",
    "test:cli": "pnpm --filter taro-shadcn test",
    "release": "node scripts/release.js",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "echo skip weapp-tw patch"
  },
  "pnpm": {
    "patchedDependencies": {
      "@tarojs/plugin-mini-ci@4.1.9": "packages/docs/patches/@tarojs__plugin-mini-ci@4.1.9.patch"
    }
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "pnpm": ">=9.0.0"
  }
}