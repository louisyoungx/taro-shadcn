{
  "name": "taro-shadcn-ui",
  "private": true,
  "description": "Taro Shadcn UI Component Library Workspace",
  "scripts": {
    "dev:docs": "pnpm --filter @taro-shadcn/docs dev:web",
    "build:docs": "pnpm --filter @taro-shadcn/docs build:web",
    "lint": "pnpm --filter \"*\" lint",
    "tsc": "pnpm --filter \"*\" tsc",
    "test:cli": "pnpm --filter taro-shadcn test",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "echo skip weapp-tw patch"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "only-allow": "^1.2.2",
    "typescript": "^5.4.5",
    "weapp-tailwindcss": "^4.10.3"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "@tarojs/plugin-mini-ci@4.1.9": "patches/@tarojs__plugin-mini-ci@4.1.9.patch"
    }
  }
}